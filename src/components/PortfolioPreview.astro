---
import type { CollectionEntry } from 'astro:content';

interface Props {
    project: CollectionEntry<'work'>;
}

const { data, id } = Astro.props.project;

/** * This gets the '/clashwithusuf/' string from your astro.config.mjs 
 * so your images and links don't break on GitHub.
 */
const base = import.meta.env.BASE_URL;
---

<a class="card" href={`${base}work/${id}`}>
    <img 
        src={`${base}${data.img}`} 
        alt={data.img_alt || ''} 
        loading="lazy" 
        decoding="async" 
    />
</a>

<style>
    .card {
        display: grid;
        grid-template: auto 1fr / auto 1fr;
        height: 11rem;
        background: var(--gradient-subtle);
        border: 1px solid var(--gray-800);
        border-radius: 0.75rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        text-decoration: none;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    /* Added a cleaner hover effect since we're fixing things */
    .card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
        border-color: var(--accent-light);
    }

    img {
        grid-area: 1 / 1 / 3 / 3;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    @media (min-width: 50em) {
        .card {
            height: 22rem;
            border-radius: 1.5rem;
        }
    }
</style>