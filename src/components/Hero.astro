---
interface Props {
    title: string;
    tagline?: string;
    align?: 'start' | 'center';
}

const { align = 'center', tagline, title } = Astro.props;
---

<div class:list={['hero stack gap-4', align]}>
    <div class="stack gap-2 animate-in">
        <h1 class="title">{title}</h1>
        {tagline && <p class="tagline">{tagline}</p>}
    </div>
    <slot />
</div>

<style>
    .hero {
        font-size: var(--text-lg);
        text-align: center;
    }

    /* Added a smooth entrance animation */
    .animate-in {
        animation: fadeInUp 0.8s ease-out forwards;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .title,
    .tagline {
        max-width: 37ch;
        margin-inline: auto;
    }

    .title {
        font-size: var(--text-3xl);
        color: var(--gray-0);
        line-height: 1.1;
    }

    .tagline {
        color: var(--gray-400);
    }

    @media (min-width: 50em) {
        .hero {
            font-size: var(--text-xl);
        }

        .start {
            text-align: start;
        }

        .start .title,
        .start .tagline {
            margin-inline: unset;
        }

        .title {
            font-size: var(--text-5xl);
        }
    }
</style>